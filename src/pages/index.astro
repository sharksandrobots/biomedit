---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Add an entry here each time you drop a new deliverable into public/roughs.
const roughs = [
  {
    title: 'Identity Rough v0.1',
    description: 'Typographic direction comparison — Space Grotesk / Fraunces / Archivo Black',
    href: '/roughs/biomedit-identity-rough.html',
  },
];
---
<Layout title="BiomEdit — Starbriq workspace">
  <h1>BiomEdit</h1>
  <p style="color:#565660;">Working space for brand identity, research, and design deliverables.</p>

  <h2 style="margin-top:48px;">Roughs &amp; deliverables</h2>
  <ul style="list-style:none; padding:0;">
    {roughs.map((r) => (
      <li style="border:1px solid #E4E3DD; border-radius:6px; padding:16px 20px; margin-bottom:12px;">
        <a href={r.href} style="font-weight:600; color:#2B3682; text-decoration:none;">{r.title}</a>
        <p style="margin:6px 0 0; font-size:14px; color:#565660;">{r.description}</p>
      </li>
    ))}
  </ul>

  <h2 style="margin-top:48px;">Recent notes</h2>
  <ul style="list-style:none; padding:0;">
    {notes.map((note) => (
      <li style="border-bottom:1px solid #E4E3DD; padding:12px 0;">
        <a href={`/notes/${note.slug}`} style="font-weight:600; color:#2B3682; text-decoration:none;">
          {note.data.title}
        </a>
        <p style="margin:4px 0 0; font-size:13px; color:#8C8B80;">
          {note.data.date.toDateString()} — {note.data.summary}
        </p>
      </li>
    ))}
  </ul>
</Layout>
