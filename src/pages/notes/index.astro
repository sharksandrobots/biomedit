---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Layout title="Notes — BiomEdit">
  <h1>Notes</h1>
  <ul style="list-style:none; padding:0;">
    {notes.map((note) => (
      <li style="border-bottom:1px solid #E4E3DD; padding:12px 0;">
        <a href={`/notes/${note.slug}`} style="font-weight:600; color:#2B3682; text-decoration:none;">
          {note.data.title}
        </a>
        <p style="margin:4px 0 0; font-size:13px; color:#8C8B80;">{note.data.date.toDateString()}</p>
      </li>
    ))}
  </ul>
</Layout>
