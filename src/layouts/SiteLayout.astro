---
// Layout for real public-facing BiomEdit pages (Company, Science, Pipeline, etc.)
// Distinct from src/layouts/Layout.astro, which is the internal Starbriq workspace shell.

import '../styles/tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  theme?: 'light' | 'dark';
}
const { title, theme = 'light' } = Astro.props;
