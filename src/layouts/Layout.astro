---
import '../styles/tokens.css';

interface Props {
  title: string;
  theme?: 'light' | 'dark'; // defaults to light; pass 'dark' to preview dark theme on a given page
}
const { title, theme = 'light' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=PT+Sans:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    rel="stylesheet"
  />
  <style>
    header {
      padding: 24px 40px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    header a { color: var(--link-color); text-decoration: none; font-weight: 600; }
    nav a { margin-left: 20px; font-size: 14px; color: var(--text-primary); text-decoration: none; }
    main { max-width: 900px; margin: 0 auto; padding: 48px 40px; }
    footer { text-align: center; padding: 32px; font-size: 12px; color: var(--text-tertiary); }
  </style>
</head>
<body>
  <header>
    <a href="/">BiomEdit — Starbriq workspace</a>
    <nav>
      <a href="/">Home</a>
      <a href="/notes">Notes</a>
      <a href="/styleguide">Styleguide</a>
      <a href="/home" target="_blank" rel="noopener">Site in progress</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>Internal working site — not for external distribution.</footer>
</body>
</html>
